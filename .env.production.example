# === AI Governance Platform — Production Environment ===

# Database (internal Docker network — use service name as host)
DATABASE_URL=postgresql://governance:CHANGE_ME_STRONG_PASSWORD@postgres:5432/governance
POSTGRES_USER=governance
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=governance

# Redis
REDIS_URL=redis://redis:6379

# NATS
NATS_URL=nats://nats:4222

# API
API_PORT=4000
API_HOST=0.0.0.0
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_AT_LEAST_32_CHARS

# Frontend (use Nginx proxy URL for browser access)
NEXT_PUBLIC_API_URL=http://localhost/api
NEXT_PUBLIC_WS_URL=ws://localhost/api

# Connectors (optional — add credentials as needed)
LANGSMITH_API_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
